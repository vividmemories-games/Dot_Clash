# cloud_firestore (Firebase iOS 12.x) requires iOS 15+ per plugin podspec.
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# firebase_crashlytics podspec shells out with an unquoted -p path; breaks when the
# project lives under a directory with spaces (e.g. "Personal Projects 2").
def patch_firebase_crashlytics_podspec_paths
  %w[ios macos].each do |platform|
    podspec = File.expand_path(
      ".symlinks/plugins/firebase_crashlytics/#{platform}/firebase_crashlytics.podspec",
      __dir__,
    )
    next unless File.exist?(podspec)

    content = File.read(podspec)
    broken = 'system("ruby #{current_dir}/crashlytics_add_upload_symbols -f -p #{project_dir} -n Runner.xcodeproj")'
    fixed = 'system("ruby \\"#{current_dir}/crashlytics_add_upload_symbols\\" -f -p \\"#{project_dir}\\" -n Runner.xcodeproj")'
    next if content.include?(fixed) || !content.include?(broken)

    File.write(podspec, content.sub(broken, fixed))
    Pod::UI.puts "Patched firebase_crashlytics podspec (#{platform}) for paths with spaces"
  end
end

patch_firebase_crashlytics_podspec_paths

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
