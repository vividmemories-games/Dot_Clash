# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Cursor IDE debug logs (keep .cursor/rules/)
.cursor/debug-*.log

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# iOS AdMob override for closed-testing prod builds (scripts/set_beta_ads_native.sh)
/ios/Flutter/BetaAdsOverride.xcconfig
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Platform build outputs (not covered by /build/)
/ios/build/
/android/.gradle/
/android/app/build/
/android/build/

# Firebase Cloud Functions — source is in functions/src/; rebuild with npm run build
functions/node_modules/
functions/lib/
functions/.env
functions/.env.*
firebase-debug.log
firebase-debug.*.log

# Apple / signing secrets — never commit (store locally or in CI secrets only)
*.p8
*.pem
ios/Security Key/
*firebase-adminsdk*.json
