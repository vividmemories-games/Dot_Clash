rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Profile fields written only by Cloud Functions (Admin SDK bypasses rules).
    function profileServerOnlyKeys() {
      return [
        'campaignStars',
        'lastCampaignLevelId',
        'dailyPuzzleDate',
        'dailyPuzzleLevelId',
        'dailyPuzzleCompleted',
        'dailyPuzzleStreak',
        'dailyMissions',
      ];
    }

    function profileClientUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(profileServerOnlyKeys());
    }

    // Dev fallback when Cloud Functions are not deployed yet.
    function campaignProgressClientUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let allowed = [
        'campaignStars', 'lastCampaignLevelId', 'level', 'coins', 'xp',
        'gamesPlayed', 'wins', 'losses', 'lives', 'nextLifeAt', 'dailyMissions', 'updatedAt',
      ];
      return changed.hasOnly(allowed);
    }

    function dailyPuzzleClientUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let allowed = [
        'dailyPuzzleDate', 'dailyPuzzleLevelId', 'dailyPuzzleCompleted', 'dailyPuzzleStreak',
        'coins', 'dailyMissions', 'updatedAt',
      ];
      return changed.hasOnly(allowed);
    }

    function missionClaimClientUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['coins', 'dailyMissions', 'updatedAt']);
    }

    function profileUpdateAllowed() {
      return profileClientUpdateAllowed()
        || campaignProgressClientUpdate()
        || dailyPuzzleClientUpdate()
        || missionClaimClientUpdate();
    }

    function validMatchCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['outcome', 'modeLabel', 'opponentLabel', 'playedAt'])
        && d.outcome is string
        && d.modeLabel is string
        && d.opponentLabel is string
        && d.playedAt is timestamp;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && profileUpdateAllowed();
      allow delete: if false;

      match /matches/{matchId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && validMatchCreate();
        allow update, delete: if false;
      }
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /worlds/{worldId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /levels/{levelId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // Written only by Cloud Functions (Admin SDK).
    match /mail/{docId} {
      allow read, write: if false;
    }
    match /contactSubmissions/{docId} {
      allow read, write: if false;
    }
    match /contactRateLimit/{docId} {
      allow read, write: if false;
    }
    match /accountDeletions/{docId} {
      allow read, write: if false;
    }
  }
}
