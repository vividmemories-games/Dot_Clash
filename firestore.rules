rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Profile security model ───────────────────────────────────────────────
    // Clients may only change display/cosmetic equip fields.
    // All economy, progression, IAP, lives, missions, and inventory fields are
    // written exclusively by Cloud Functions (Admin SDK bypasses these rules).

    function profileClientWritableKeys() {
      return ['displayName', 'themeId', 'avatarId', 'initialSkinId', 'updatedAt'];
    }

    function profileClientUpdateAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(profileClientWritableKeys());
    }

    function validProfileCreate() {
      let d = request.resource.data;
      return d.uid == request.auth.uid
        && d.displayName is string
        && d.coins == 200
        && d.xp == 0
        && d.level == 1
        && d.wins == 0
        && d.losses == 0
        && d.ties == 0
        && d.gamesPlayed == 0
        && d.winStreak == 0
        && d.bestWinStreak == 0
        && d.seasonId is string
        && d.rating == 1000
        && d.seasonBestRating == 1000
        && d.seasonWins == 0
        && d.seasonLosses == 0
        && d.seasonTies == 0
        && d.themeId == 'theme_neon_default'
        && d.avatarId == 'avatar_orb_cyan'
        && d.initialSkinId == 'initial_skin_classic'
        && d.removeAds == false
        && d.ownedThemeIds.hasOnly(['theme_neon_default'])
        && d.ownedAvatarIds.hasOnly(['avatar_orb_cyan'])
        && d.ownedInitialSkinIds.hasOnly(['initial_skin_classic'])
        && d.lives == 5
        && d.nextLifeAt == null
        && d.lastDailyClaimAt == null
        && d.lastRewardedAdAt == null
        && (!('campaignStars' in d) || d.campaignStars.size() == 0)
        && (!('lastCampaignLevelId' in d) || d.lastCampaignLevelId == null)
        && (!('dailyPuzzleDate' in d) || d.dailyPuzzleDate == null)
        && (!('dailyPuzzleLevelId' in d) || d.dailyPuzzleLevelId == null)
        && d.dailyPuzzleCompleted == false
        && d.dailyPuzzleStreak == 0
        && d.dailyMissions.wins == 0
        && d.dailyMissions.games == 0
        && d.dailyMissions.boxes == 0
        && d.dailyMissions.claimed.size() == 0
        && (!('powerUpInventory' in d) || d.powerUpInventory.size() == 0);
    }

    function validMatchCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly(['outcome', 'modeLabel', 'opponentLabel', 'playedAt', 'opponentUid', 'challengeCode'])
        && d.outcome is string
        && d.modeLabel is string
        && d.opponentLabel is string
        && d.playedAt is timestamp
        && (!('opponentUid' in d) || d.opponentUid is string)
        && (!('challengeCode' in d) || d.challengeCode is string);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && validProfileCreate();
      allow update: if isOwner(uid) && profileClientUpdateAllowed();
      allow delete: if false;

      match /matches/{matchId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && validMatchCreate();
        allow update, delete: if false;
      }
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /worlds/{worldId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /levels/{levelId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // Written only by Cloud Functions (Admin SDK).
    match /mail/{docId} {
      allow read, write: if false;
    }
    match /contactSubmissions/{docId} {
      allow read, write: if false;
    }
    match /contactRateLimit/{docId} {
      allow read, write: if false;
    }
    match /accountDeletions/{docId} {
      allow read, write: if false;
    }

    match /challenges/{code} {
      // Waiting: any signed-in user with the code (invite link) may read to join.
      // Active/finished: host and guest only.
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.hostUid
            || request.auth.uid == resource.data.guestUid
            || resource.data.status == 'waiting');
      allow write: if false;
    }
  }
}
